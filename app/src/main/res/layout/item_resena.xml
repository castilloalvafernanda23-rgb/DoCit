<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_redondeado"
    android:padding="14dp"
    android:layout_marginVertical="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:id="@+id/tUser"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textStyle="bold" android:textColor="@color/negroSuave"/>
        <TextView android:id="@+id/tCalifR"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/estadoPendiente" android:textStyle="bold"/>
    </LinearLayout>

    <TextView android:id="@+id/tComent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/negroSuave"
        android:layout_marginTop="4dp"/>

    <TextView android:id="@+id/tFechaR"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/gris"
        android:textSize="11sp"
        android:layout_marginTop="4dp"/>
</LinearLayout>
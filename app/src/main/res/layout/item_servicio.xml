<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_redondeado"
    android:padding="14dp"
    android:layout_marginVertical="5dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView android:id="@+id/tNombreServ" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textStyle="bold" android:textColor="@color/negroSuave"/>
        <TextView android:id="@+id/tDescServ" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/gris" android:textSize="12sp"/>
        <TextView android:id="@+id/tDur" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/gris" android:textSize="11sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tPrecio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/rojoDocit"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_gravity="center_vertical"/>
</LinearLayout>
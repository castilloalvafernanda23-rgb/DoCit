<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgDoc"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_medico"
            android:background="@drawable/circle_pink"
            android:padding="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView android:id="@+id/tNombre" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textStyle="bold" android:textSize="16sp" android:textColor="@color/negroSuave"/>
            <TextView android:id="@+id/tEsp" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/rojoDocit" android:textSize="13sp"/>
            <TextView android:id="@+id/tDesc" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/gris" android:textSize="12sp" android:maxLines="2" android:ellipsize="end"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tCalif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="@color/rojoDocit"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
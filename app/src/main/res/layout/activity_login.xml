<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanco"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/logo_docit"
            android:layout_marginTop="40dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DoCit"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="@color/rojoDocit"
            android:layout_marginTop="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lema"
            android:textColor="@color/gris"
            android:layout_marginBottom="36dp"/>

        <EditText
            android:id="@+id/txtCorreo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="@string/correo"
            android:inputType="textEmailAddress"
            android:background="@drawable/edittext_borde"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="14dp"/>

        <EditText
            android:id="@+id/txtContra"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="@string/contra"
            android:inputType="textPassword"
            android:background="@drawable/edittext_borde"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEntrar"
            style="@style/botonRojo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/iniciar"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIrRegistro"
            style="@style/botonBlanco"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Crear cuenta nueva"/>

        <TextView
            android:id="@+id/txtOlvideContra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Olvidé mi contraseña"
            android:textColor="@color/rojoDocit"
            android:layout_marginTop="20dp"
            android:padding="8dp"/>
    </LinearLayout>
</ScrollView>
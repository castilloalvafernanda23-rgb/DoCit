<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blancoHueso">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.smarteist.autoimageslider.SliderView
            android:id="@+id/imageSlider"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            app:sliderAnimationDuration="600"
            app:sliderAutoCycleDirection="back_and_forth"
            app:sliderIndicatorAnimationDuration="600"
            app:sliderIndicatorGravity="center_horizontal|bottom"
            app:sliderIndicatorMargin="15dp"
            app:sliderIndicatorOrientation="horizontal"
            app:sliderIndicatorPadding="3dp"
            app:sliderIndicatorRadius="2dp"
            app:sliderIndicatorSelectedColor="@color/rojoDocit"
            app:sliderIndicatorUnselectedColor="@color/blanco"
            app:sliderScrollTimeInSec="3"
            app:sliderStartAutoCycle="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView android:id="@+id/lblNombreDoc"
                style="@style/textoTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView android:id="@+id/lblEsp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/rojoDocit"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView android:id="@+id/lblCalif"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/estadoPendiente"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

            <TextView android:id="@+id/lblDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/negroSuave"
                android:layout_marginTop="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Servicios y precios"
                style="@style/textoTitulo"
                android:textSize="17sp"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="6dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvServicios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reseñas"
                style="@style/textoTitulo"
                android:textSize="17sp"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="6dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvResenas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="18dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWhats"
                    style="@style/botonBlanco"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="50dp"
                    android:text="WhatsApp"/>

                <View android:layout_width="10dp" android:layout_height="1dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLlamar"
                    style="@style/botonBlanco"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="50dp"
                    android:text="Llamar"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAgendar"
                style="@style/botonRojo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:text="Agendar cita"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>